# Freeze Dry Gallery — Configuration
# Copy to .env and fill in your values

# Your wallet address(es) — comma-separated
WALLETS=YourWalletAddressHere

# Gallery display name
GALLERY_NAME=My Gallery

# Server port
PORT=3000

# Helius API key (free at helius.dev — speeds up scanning)
# Leave blank to use public Solana RPC
# HELIUS_API_KEY=your-key-here

# Data directory for SQLite database
# DATA_DIR=./data

# How often to check for new inscriptions (ms, default 30 min)
# POLL_INTERVAL=1800000
